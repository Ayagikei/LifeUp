<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="net.sarasarasa.lifeup">

    <!-- To auto-complete the email text field in the login form with the user's emails -->
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />
    <uses-permission android:name="android.permission.READ_PROFILE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- To access Google+ APIs: -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name="net.sarasarasa.lifeup.application.LifeUpApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:name=".activities.SplashActivity"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/AppTheme.SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".activities.WelcomeActivity"
            android:label="@string/app_name"
            android:theme="@style/AppTheme.TranslucentTheme" />
        <activity
            android:name=".activities.MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.Main" />
        <activity
            android:name=".activities.LoginActivity"
            android:label="@string/title_activity_login"
            android:parentActivityName=".activities.MainActivity"
            android:theme="@style/AppTheme.Login"
            android:windowSoftInputMode="stateHidden|stateAlwaysHidden" />
        <activity
            android:name=".activities.SettingActivity"
            android:label="设置"
            android:parentActivityName=".activities.MainActivity"
            android:theme="@style/AppTheme.Login" />
        <activity
            android:name=".activities.AddToDoItemActivity"
            android:label="@string/title_activity_add_to_do_item"
            android:parentActivityName=".activities.MainActivity"
            android:theme="@style/AppTheme.Login">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="net.sarasarasa.lifeup.activities.MainActivity" />
        </activity>
        <activity
            android:name=".activities.AddTeamActivity"
            android:label="@string/title_activity_add_team_item"
            android:parentActivityName=".activities.MainActivity"
            android:theme="@style/AppTheme.Login">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="net.sarasarasa.lifeup.activities.MainActivity" />
        </activity>
        <activity
            android:name=".activities.TeamActivity"
            android:label="@string/title_activity_team"
            android:parentActivityName=".activities.MainActivity"
            android:theme="@style/AppTheme.Login">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="net.sarasarasa.lifeup.activities.MainActivity" />
        </activity>
        <activity
            android:name=".activities.UserActivity"
            android:label="@string/title_activity_user"
            android:parentActivityName=".activities.MainActivity"
            android:theme="@style/AppTheme.Login">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="net.sarasarasa.lifeup.activities.MainActivity" />
        </activity>
    </application>

</manifest>