<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".activities.AddToDoItemActivity"
    tools:showIn="@layout/activity_add_to_do_item">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/cw_basic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="10dp"
            app:cardElevation="5dp"
            app:contentPadding="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.51"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tw_exp_pie_chart_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/xml_add_to_do_basic_header"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Space
                    android:id="@+id/sp_to_do_text"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    app:layout_constraintBottom_toBottomOf="@+id/til_toDoText"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/til_toDoText" />

                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxEms="16"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp"
                    android:text="@string/category_default"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@+id/tw_exp_pie_chart_header"
                    app:layout_constraintStart_toEndOf="@+id/tw_exp_pie_chart_header"
                    app:layout_constraintTop_toTopOf="@+id/tw_exp_pie_chart_header" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_toDoText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:hint="@string/xml_add_to_content"
                    app:errorEnabled="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tv_category">

                    <net.sarasarasa.lifeup.view.FixedTextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <Space
                    android:id="@+id/sp_remark"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    app:layout_constraintBottom_toBottomOf="@+id/til_remark"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/til_remark" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_remark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/xml_add_to_do_remark"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/til_toDoText">

                    <net.sarasarasa.lifeup.view.FixedTextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageView
                    android:id="@+id/iv_basic_question"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_question" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>


        <androidx.cardview.widget.CardView
            android:id="@+id/cw_bonus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="10dp"
            app:cardElevation="5dp"
            app:contentPadding="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.51"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cw_basic">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tw_abbrHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/xml_add_to_do_bouns_header"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tw_urgence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="16dp"
                    android:layout_weight="1"
                    android:text="@string/xml_add_to_do_urgency"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tw_abbrHeader" />

                <com.jaygoo.widget.RangeSeekBar
                    android:id="@+id/sb_urgence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="2dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tw_urgence"
                    app:rsb_indicator_height="20dp"
                    app:rsb_indicator_padding_left="10dp"
                    app:rsb_indicator_padding_right="10dp"
                    app:rsb_indicator_show_mode="alwaysShow"
                    app:rsb_max="99.0"
                    app:rsb_mode="single"
                    app:rsb_progress_color="#ffffbb33"
                    app:rsb_progress_default_color="@color/rsbColorThumbPressed"
                    app:rsb_progress_height="4dp"
                    app:rsb_progress_radius="0dp"
                    app:rsb_thumb_drawable="@drawable/thumb_yellow"
                    app:rsb_thumb_size="22dp"
                    app:rsb_tick_mark_gravity="center"
                    app:rsb_tick_mark_mode="other"
                    app:rsb_tick_mark_number="3"
                    app:rsb_tick_mark_text_array="@array/wordsArray"
                    app:rsb_tick_mark_text_color="#ffffbb33"
                    app:rsb_tick_mark_text_margin="17dp" />

                <TextView
                    android:id="@+id/tw_difficulty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/xml_add_to_do_difficulty"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/sb_urgence" />

                <com.jaygoo.widget.RangeSeekBar
                    android:id="@+id/sb_difficulty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="2dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tw_difficulty"
                    app:rsb_indicator_height="20dp"
                    app:rsb_indicator_padding_left="10dp"
                    app:rsb_indicator_padding_right="10dp"
                    app:rsb_indicator_show_mode="alwaysShow"
                    app:rsb_max="99.0"
                    app:rsb_mode="single"
                    app:rsb_progress_color="#ffffbb33"
                    app:rsb_progress_default_color="@color/rsbColorThumbPressed"
                    app:rsb_progress_height="4dp"
                    app:rsb_progress_radius="0dp"
                    app:rsb_thumb_drawable="@drawable/thumb_yellow"
                    app:rsb_thumb_size="22dp"
                    app:rsb_tick_mark_gravity="center"
                    app:rsb_tick_mark_mode="other"
                    app:rsb_tick_mark_number="3"
                    app:rsb_tick_mark_text_array="@array/wordsArray"
                    app:rsb_tick_mark_text_color="#ffffbb33"
                    app:rsb_tick_mark_text_margin="17dp" />

                <TextView
                    android:id="@+id/tw_skills"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/xml_add_to_do_attrs"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/sb_difficulty" />

                <LinearLayout
                    android:id="@+id/linearLayout2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tw_skills">

                    <ImageView
                        android:id="@+id/iv_strength"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:onClick="switchBtn"
                        android:padding="2dp"
                        app:srcCompat="@drawable/ic_abbr_strength" />

                    <ImageView
                        android:id="@+id/iv_learning"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:onClick="switchBtn"
                        android:padding="2dp"
                        app:srcCompat="@drawable/ic_abbr_learning" />

                    <ImageView
                        android:id="@+id/iv_charm"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:onClick="switchBtn"
                        android:padding="2dp"
                        app:srcCompat="@drawable/ic_abbr_charm" />

                    <ImageView
                        android:id="@+id/iv_endurance"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:onClick="switchBtn"
                        android:padding="2dp"
                        app:srcCompat="@drawable/ic_abbr_endurance" />

                    <ImageView
                        android:id="@+id/iv_vitality"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:onClick="switchBtn"
                        android:padding="2dp"
                        app:srcCompat="@drawable/ic_abbr_vitality" />

                    <ImageView
                        android:id="@+id/iv_creative"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:onClick="switchBtn"
                        android:padding="2dp"
                        app:srcCompat="@drawable/ic_abbr_creative" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ly_icon_desc"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="1dp"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/linearLayout2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/attr_strength"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/attr_learning"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/attr_charm"
                        android:textSize="12sp" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/attr_endurance"
                        android:textSize="12sp" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/attr_vitality"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/attr_creative"
                        android:textSize="12sp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/imageView8"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:onClick="showDialogAttribution"
                    app:layout_constraintBottom_toBottomOf="@+id/tw_skills"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tw_skills"
                    app:srcCompat="@drawable/ic_question" />

                <ImageView
                    android:id="@+id/iv_bouns_question"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_question" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cw_extra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="@dimen/dp_10"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="10dp"
            app:cardElevation="5dp"
            app:contentPadding="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.51"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cw_basic">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_extra"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_extra_question"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_question" />

                <TextView
                    android:id="@+id/tw_extraHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/xml_add_to_do_extra_header"
                    android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Space
                    android:id="@+id/sp_remind_date"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    app:layout_constraintBottom_toBottomOf="@+id/til_remindDate"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/til_remindDate" />

                <net.sarasarasa.lifeup.view.CustomTextInputLayout
                    android:id="@+id/til_remindDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/xml_add_to_do_remind_date"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tw_extraHeader">

                    <net.sarasarasa.lifeup.view.FixedTextInputEditText
                        android:id="@+id/et_remindDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_alarm_black_24dp"
                        android:drawablePadding="4dp"
                        android:freezesText="false"
                        android:inputType="date"
                        android:singleLine="true"
                        android:textSize="16sp" />
                </net.sarasarasa.lifeup.view.CustomTextInputLayout>

                <TextView
                    android:id="@+id/btn_remind_reset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:onClick="finishRemindReset"
                    android:text="@string/xml_reset"
                    android:textColor="@color/colorAccent"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="@+id/til_deadLine"
                    app:layout_constraintTop_toTopOf="@+id/til_remindDate" />

                <Space
                    android:id="@+id/sp_startTime"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    app:layout_constraintBottom_toBottomOf="@+id/til_startTime"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/til_startTime" />

                <net.sarasarasa.lifeup.view.CustomTextInputLayout
                    android:id="@+id/til_startTime"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/xml_add_to_do_start_time"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_remindDate">

                    <net.sarasarasa.lifeup.view.FixedTextInputEditText
                        android:id="@+id/et_startTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_event_black_24dp"
                        android:drawablePadding="4dp"
                        android:freezesText="false"
                        android:inputType="date"
                        android:singleLine="true"
                        android:textSize="16sp" />
                </net.sarasarasa.lifeup.view.CustomTextInputLayout>

                <TextView
                    android:id="@+id/btn_start_time_reset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:onClick="startTimeReset"
                    android:text="@string/xml_reset"
                    android:textColor="@color/colorAccent"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="@+id/til_startTime"
                    app:layout_constraintTop_toTopOf="@+id/til_startTime" />

                <Space
                    android:id="@+id/sp_deadLine"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    app:layout_constraintBottom_toBottomOf="@+id/til_deadLine"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/til_deadLine" />

                <net.sarasarasa.lifeup.view.CustomTextInputLayout
                    android:id="@+id/til_deadLine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/xml_add_to_do_deadline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_startTime">

                    <net.sarasarasa.lifeup.view.FixedTextInputEditText
                        android:id="@+id/et_expire_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_date_range_black_24dp"
                        android:drawablePadding="4dp"
                        android:freezesText="false"
                        android:inputType="date"
                        android:singleLine="true"
                        android:textSize="16sp" />
                </net.sarasarasa.lifeup.view.CustomTextInputLayout>

                <TextView
                    android:id="@+id/btn_ddl_reset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:onClick="expireTimeReset"
                    android:text="@string/xml_reset"
                    android:textColor="@color/colorAccent"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="@+id/til_deadLine"
                    app:layout_constraintTop_toTopOf="@+id/til_deadLine" />

                <TextView
                    android:id="@+id/btn_ddl_set_spec_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/xml_add_to_do_set_time"
                    android:textColor="@color/colorAccent"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toStartOf="@+id/btn_ddl_reset"
                    app:layout_constraintTop_toTopOf="@+id/til_deadLine" />

                <Space
                    android:id="@+id/sp_repeat"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    app:layout_constraintBottom_toBottomOf="@+id/til_repeat"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/til_repeat" />

                <net.sarasarasa.lifeup.view.CustomTextInputLayout
                    android:id="@+id/til_repeat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/xml_add_to_do_repeat"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_deadLine">

                    <net.sarasarasa.lifeup.view.FixedTextInputEditText
                        android:id="@+id/et_repeat"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:drawableStart="@drawable/ic_loop_black_24dp"
                        android:drawablePadding="4dp"
                        android:inputType="date"
                        android:singleLine="true"
                        android:textSize="16sp" />
                </net.sarasarasa.lifeup.view.CustomTextInputLayout>

                <TextView
                    android:id="@+id/btn_repeat_set_ignore_day_of_week"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/xml_add_to_do_set_ignore"
                    android:textColor="@color/colorAccent"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="@id/til_repeat"
                    app:layout_constraintTop_toTopOf="@+id/til_repeat" />

                <Space
                    android:id="@+id/sp_target"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    app:layout_constraintBottom_toBottomOf="@+id/til_target"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/til_target" />

                <net.sarasarasa.lifeup.view.CustomTextInputLayout
                    android:id="@+id/til_target"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/xml_add_to_do_target_times"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_repeat">

                    <net.sarasarasa.lifeup.view.FixedTextInputEditText
                        android:id="@+id/et_target"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:drawableStart="@drawable/ic_grade_black_24dp"
                        android:drawablePadding="4dp"
                        android:inputType="number"
                        android:maxLength="4"
                        android:singleLine="true"
                        android:textSize="16sp" />
                </net.sarasarasa.lifeup.view.CustomTextInputLayout>

                <Space
                    android:id="@+id/sp_complete_reward"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    app:layout_constraintBottom_toBottomOf="@+id/til_complete_reward"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/til_complete_reward" />

                <net.sarasarasa.lifeup.view.CustomTextInputLayout
                    android:id="@+id/til_complete_reward"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:hint="@string/xml_add_to_do_complete_reward"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_target">

                    <net.sarasarasa.lifeup.view.FixedTextInputEditText
                        android:id="@+id/et_complete_reward"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:drawableStart="@drawable/ic_card_giftcard_black_24dp"
                        android:drawablePadding="4dp"
                        android:singleLine="true"
                        android:textSize="16sp" />
                </net.sarasarasa.lifeup.view.CustomTextInputLayout>

                <!--                <Switch
                                    android:id="@+id/switch1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="16dp"
                                    android:enabled="false"
                                    android:paddingLeft="2dp"
                                    android:text="分享到社区"
                                    android:textSize="18sp"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="til_target" />--> <!-- here should be til_deadLine or til_repeat -->

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/btn_show_more"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            android:layout_marginBottom="16.0dip"
            android:onClick="showMoreOptions"
            android:text="@string/xml_add_to_do_more_options"
            android:textAlignment="center"
            android:textColor="@color/blue" />

    </LinearLayout>
</ScrollView>
