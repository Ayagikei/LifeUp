<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background_color"
    android:orientation="vertical"
    tools:context="net.sarasarasa.lifeup.activities.BackupActivity"
    tools:showIn="@layout/activity_backup">

    <LinearLayout
        android:id="@+id/ly_backup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tv_backup_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="备份"
            android:textColor="@android:color/black"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_backup_tint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:textColor="@color/design_default_color_primary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_backup_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="将你的数据备份到外部存储空间。\n备份的内容包括：待办事项、计步数据、经验值等级等数据。"
            android:textSize="12sp" />

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:background="?android:attr/listDivider" />

    <LinearLayout
        android:id="@+id/ly_restore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tv_restore_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="恢复"
            android:textColor="@android:color/black"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_restore_tint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:textColor="@color/design_default_color_primary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_restore_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text="从你的外部存储空间中恢复数据。\n注意：现在的数据将会被覆盖，谨慎操作。"
            android:textSize="12sp" />

    </LinearLayout>

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:background="?android:attr/listDivider" />


</LinearLayout>
