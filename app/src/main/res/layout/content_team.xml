<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent">

    <android.support.v7.widget.CardView
        android:id="@+id/mainCardView"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#ffffff"
        app:cardCornerRadius="10dp"
        app:cardElevation="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/textView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/smssdk_black" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="2dp"
                android:text="建立了3天"
                android:textColor="@color/smssdk_black"
                app:layout_constraintStart_toEndOf="@+id/imageView4"
                app:layout_constraintTop_toTopOf="@+id/imageView4" />

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_dot"
                app:layout_constraintStart_toStartOf="@+id/imageView3"
                app:layout_constraintTop_toBottomOf="@+id/imageView3" />

            <TextView
                android:id="@+id/textView_userDesc2"
                android:layout_width="304dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="我们建立这个团队是为了一起学习日语，共同进步！"
                app:layout_constraintStart_toStartOf="@+id/imageView"
                app:layout_constraintTop_toBottomOf="@+id/imageView" />

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:paddingTop="@dimen/nav_header_vertical_spacing"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_team_fujisan" />

            <TextView
                android:id="@+id/textView_userName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="8dp"
                android:paddingTop="@dimen/nav_header_vertical_spacing"
                android:text="团队一句话描述"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                app:layout_constraintStart_toEndOf="@+id/imageView"
                app:layout_constraintTop_toTopOf="@+id/imageView" />

            <TextView
                android:id="@+id/textView_userDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="组织者：UserName"
                app:layout_constraintStart_toStartOf="@+id/textView_userName"
                app:layout_constraintTop_toBottomOf="@+id/textView_userName" />

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:src="@drawable/ic_dot"
                app:layout_constraintStart_toStartOf="@+id/imageView"
                app:layout_constraintTop_toBottomOf="@+id/textView_userDesc2" />

            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="2dp"
                android:text="完成了168个待办事项"
                android:textColor="@color/smssdk_black"
                app:layout_constraintStart_toEndOf="@+id/imageView3"
                app:layout_constraintTop_toTopOf="@+id/imageView3" />
        </android.support.constraint.ConstraintLayout>
    </android.support.v7.widget.CardView>

    <android.support.v7.widget.CardView
        android:id="@+id/activityCardViewActivity"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="8dp"
        android:paddingBottom="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="10dp"
        app:cardElevation="5dp"
        app:contentPadding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.51"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mainCardView">

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tw_ddlText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="2019/1/1 12:00"
                android:textColor="@android:color/black"
                app:layout_constraintStart_toEndOf="@+id/tw_repeatTitle"
                app:layout_constraintTop_toTopOf="@+id/tw_ddlTitle" />

            <TextView
                android:id="@+id/tw_repeatText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="每日"
                android:textColor="@color/colorAccent2"
                app:layout_constraintStart_toEndOf="@+id/tw_repeatTitle"
                app:layout_constraintTop_toTopOf="@+id/tw_repeatTitle" />

            <TextView
                android:id="@+id/tw_expText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="500点"
                android:textColor="#FF9100"
                app:layout_constraintStart_toEndOf="@+id/tw_expTitle"
                app:layout_constraintTop_toTopOf="@+id/tw_expTitle" />

            <TextView
                android:id="@+id/tw_activityHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="任务"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_btn_viewAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="修改"
                android:textAppearance="@style/TextAppearance.AppCompat.Button"
                android:textColor="@color/blue"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tw_contentTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="任务内容："
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tw_activityHeader" />

            <TextView
                android:id="@+id/tw_contentText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="每日学习日语"
                android:textColor="@color/smssdk_black"
                app:layout_constraintStart_toEndOf="@+id/tw_contentTitle"
                app:layout_constraintTop_toTopOf="@+id/tw_contentTitle" />

            <TextView
                android:id="@+id/tw_remarkTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="详细描述："
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/tw_contentTitle"
                app:layout_constraintTop_toBottomOf="@+id/tw_contentTitle" />

            <TextView
                android:id="@+id/tw_remarkText"
                android:layout_width="229dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="每日学习日语词汇20个，并且进行打卡。"
                android:textColor="@color/smssdk_black"
                app:layout_constraintStart_toEndOf="@+id/tw_remarkTitle"
                app:layout_constraintTop_toTopOf="@+id/tw_remarkTitle" />

            <TextView
                android:id="@+id/tw_abbrTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="相关属性："
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/tw_contentTitle"
                app:layout_constraintTop_toBottomOf="@+id/tw_remarkText" />

            <TextView
                android:id="@+id/tw_ddlTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="截止日期："
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/tw_contentTitle"
                app:layout_constraintTop_toBottomOf="@+id/tw_repeatTitle" />

            <TextView
                android:id="@+id/tw_repeatTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="重复频次："
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/tw_contentTitle"
                app:layout_constraintTop_toBottomOf="@+id/tw_expTitle" />

            <TextView
                android:id="@+id/tw_expTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="经验奖励："
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/tw_contentTitle"
                app:layout_constraintTop_toBottomOf="@+id/tw_abbrTitle" />

            <ImageView
                android:id="@+id/iv_iconSkillFrist"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_abbr_learning"
                app:layout_constraintStart_toEndOf="@+id/tw_abbrTitle"
                app:layout_constraintTop_toBottomOf="@+id/tw_remarkText" />

            <ImageView
                android:id="@+id/iv_iconSkillSecond"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_abbr_endurance"
                app:layout_constraintStart_toEndOf="@+id/iv_iconSkillFrist"
                app:layout_constraintTop_toTopOf="@+id/iv_iconSkillFrist" />

            <ImageView
                android:id="@+id/iv_iconSkillThird"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_abbr_charm"
                app:layout_constraintStart_toEndOf="@+id/iv_iconSkillSecond"
                app:layout_constraintTop_toTopOf="@+id/iv_iconSkillFrist" />

        </android.support.constraint.ConstraintLayout>
    </android.support.v7.widget.CardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="16dp"
        app:layout_constraintTop_toBottomOf="@+id/activityCardViewActivity" />

</android.support.constraint.ConstraintLayout>