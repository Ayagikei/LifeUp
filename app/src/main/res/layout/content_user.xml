<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent">

    <android.support.v7.widget.CardView
        android:id="@+id/mainCardView"
        android:layout_width="340dp"
        android:layout_height="204dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#ffffff"
        app:cardCornerRadius="10dp"
        app:cardElevation="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="2dp"
                android:text="使用人生365天"
                android:textColor="@color/smssdk_black"
                app:layout_constraintStart_toEndOf="@+id/imageView5"
                app:layout_constraintTop_toTopOf="@+id/imageView5" />

            <ImageView
                android:id="@+id/imageView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_dot"
                app:layout_constraintStart_toStartOf="@+id/imageView3"
                app:layout_constraintTop_toBottomOf="@+id/imageView4" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="2dp"
                android:text="加入过32次团队"
                android:textColor="@color/smssdk_black"
                app:layout_constraintStart_toEndOf="@+id/imageView4"
                app:layout_constraintTop_toTopOf="@+id/imageView4" />

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_dot"
                app:layout_constraintStart_toStartOf="@+id/imageView3"
                app:layout_constraintTop_toBottomOf="@+id/imageView3" />

            <TextView
                android:id="@+id/textView_userDesc2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="人生等级：Lv.1 初出茅庐"
                android:textColor="@color/colorAccent"
                app:layout_constraintStart_toStartOf="@+id/tv_userDesc"
                app:layout_constraintTop_toBottomOf="@+id/tv_userDesc" />

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:paddingTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@mipmap/ic_launcher" />

            <TextView
                android:id="@+id/tv_userName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="8dp"
                android:paddingTop="@dimen/nav_header_vertical_spacing"
                android:text="昵称"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                app:layout_constraintStart_toEndOf="@+id/iv_avatar"
                app:layout_constraintTop_toTopOf="@+id/iv_avatar" />

            <TextView
                android:id="@+id/tv_userDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="用户名：UserName"
                app:layout_constraintStart_toStartOf="@+id/tv_userName"
                app:layout_constraintTop_toBottomOf="@+id/tv_userName" />

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:src="@drawable/ic_dot"
                app:layout_constraintStart_toStartOf="@+id/iv_avatar"
                app:layout_constraintTop_toBottomOf="@+id/iv_avatar" />

            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="2dp"
                android:text="完成了168个待办事项"
                android:textColor="@color/smssdk_black"
                app:layout_constraintStart_toEndOf="@+id/imageView3"
                app:layout_constraintTop_toTopOf="@+id/imageView3" />
        </android.support.constraint.ConstraintLayout>
    </android.support.v7.widget.CardView>

    <android.support.v7.widget.CardView
        android:id="@+id/activityCardViewActivity"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="10dp"
        app:cardElevation="5dp"
        app:contentPadding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.51"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mainCardView">

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tw_activityHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="动态"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_btn_viewAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="查看所有"
                android:textAppearance="@style/TextAppearance.AppCompat.Button"
                android:textColor="@color/blue"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@+id/tw_activityHeader">

                <android.support.constraint.ConstraintLayout
                    android:id="@+id/act1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_content_act1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="2dp"
                        android:text="一起来学日语吧！"
                        android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@+id/imageView2_act1"
                        app:layout_constraintTop_toBottomOf="@+id/tv_header_act1" />

                    <TextView
                        android:id="@+id/tv_header_act1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="周期任务-每日"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toTopOf="@+id/tv_content_act1"
                        app:layout_constraintStart_toStartOf="@+id/tv_content_act1"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/iv_iconSkillFrist_act1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="4dp"
                        android:src="@drawable/ic_abbr_learning"
                        app:layout_constraintStart_toStartOf="@+id/tv_content_act1"
                        app:layout_constraintTop_toBottomOf="@+id/tv_content_act1" />

                    <ImageView
                        android:id="@+id/iv_iconSkillSecond_act1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_abbr_endurance"
                        app:layout_constraintStart_toEndOf="@+id/iv_iconSkillFrist_act1"
                        app:layout_constraintTop_toTopOf="@+id/iv_iconSkillFrist_act1" />

                    <ImageView
                        android:id="@+id/iv_iconSkillThird_act1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_abbr_charm"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/iv_iconSkillSecond_act1"
                        app:layout_constraintTop_toTopOf="@+id/iv_iconSkillSecond_act1" />

                    <TextView
                        android:id="@+id/tv_btn_act1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:text="2018/8/14"
                        android:textAppearance="@style/TextAppearance.AppCompat.Button"
                        android:textColor="@color/blue"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_content_act1" />

                    <ImageView
                        android:id="@+id/imageView2_act1"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="24dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/ic_finish" />

                </android.support.constraint.ConstraintLayout>

                <View
                    android:id="@+id/divider_act12"
                    android:layout_width="308dp"
                    android:layout_height="1dp"
                    android:background="?android:attr/listDivider"
                    tools:layout_editor_absoluteX="8dp"
                    tools:layout_editor_absoluteY="78dp" />

                <android.support.constraint.ConstraintLayout
                    android:id="@+id/act2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_content_act2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="2dp"
                        android:text="一起来学日语吧！"
                        android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@+id/imageView2_act2"
                        app:layout_constraintTop_toBottomOf="@+id/tv_header_act2" />

                    <TextView
                        android:id="@+id/tv_header_act2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="周期任务-每日"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toTopOf="@+id/tv_content_act2"
                        app:layout_constraintStart_toStartOf="@+id/tv_content_act2"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/iv_iconSkillFrist_act2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="4dp"
                        android:src="@drawable/ic_abbr_learning"
                        app:layout_constraintStart_toStartOf="@+id/tv_content_act2"
                        app:layout_constraintTop_toBottomOf="@+id/tv_content_act2" />

                    <ImageView
                        android:id="@+id/iv_iconSkillSecond_act2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_abbr_endurance"
                        app:layout_constraintStart_toEndOf="@+id/iv_iconSkillFrist_act2"
                        app:layout_constraintTop_toTopOf="@+id/iv_iconSkillFrist_act2" />

                    <ImageView
                        android:id="@+id/iv_iconSkillThird_act2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_abbr_charm"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/iv_iconSkillSecond_act2"
                        app:layout_constraintTop_toTopOf="@+id/iv_iconSkillSecond_act2" />

                    <TextView
                        android:id="@+id/tv_btn_act2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:text="2018/8/14"
                        android:textAppearance="@style/TextAppearance.AppCompat.Button"
                        android:textColor="@color/blue"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_content_act2" />

                    <ImageView
                        android:id="@+id/imageView2_act2"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="24dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/ic_finish" />
                </android.support.constraint.ConstraintLayout>

                <View
                    android:id="@+id/divider_act23"
                    android:layout_width="308dp"
                    android:layout_height="1dp"
                    android:background="?android:attr/listDivider"
                    tools:layout_editor_absoluteX="8dp"
                    tools:layout_editor_absoluteY="78dp" />

                <android.support.constraint.ConstraintLayout
                    android:id="@+id/act3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_content_act3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="2dp"
                        android:text="一起来学日语吧！"
                        android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@+id/imageView2_act3"
                        app:layout_constraintTop_toBottomOf="@+id/tv_header_act3"
                        tools:layout_editor_absoluteY="32dp" />

                    <TextView
                        android:id="@+id/tv_header_act3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="周期任务-每日"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toTopOf="@+id/tv_content_act3"
                        app:layout_constraintStart_toStartOf="@+id/tv_content_act3"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/iv_iconSkillFrist_act3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="4dp"
                        android:src="@drawable/ic_abbr_learning"
                        app:layout_constraintStart_toStartOf="@+id/tv_content_act3"
                        app:layout_constraintTop_toBottomOf="@+id/tv_content_act3" />

                    <ImageView
                        android:id="@+id/iv_iconSkillSecond_act3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_abbr_endurance"
                        app:layout_constraintStart_toEndOf="@+id/iv_iconSkillFrist_act3"
                        app:layout_constraintTop_toTopOf="@+id/iv_iconSkillFrist_act3" />

                    <ImageView
                        android:id="@+id/iv_iconSkillThird_act3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_abbr_charm"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/iv_iconSkillSecond_act3"
                        app:layout_constraintTop_toTopOf="@+id/iv_iconSkillSecond_act3" />

                    <TextView
                        android:id="@+id/tv_btn_act3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:text="2018/8/14"
                        android:textAppearance="@style/TextAppearance.AppCompat.Button"
                        android:textColor="@color/blue"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_content_act3" />

                    <ImageView
                        android:id="@+id/imageView2_act3"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="24dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/ic_finish" />
                </android.support.constraint.ConstraintLayout>
            </LinearLayout>
        </android.support.constraint.ConstraintLayout>
    </android.support.v7.widget.CardView>


    <android.support.v7.widget.CardView
        android:id="@+id/mainCardViewstatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:paddingBottom="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="10dp"
        app:cardElevation="5dp"
        app:contentPadding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.51"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/activityCardViewActivity">

        <android.support.constraint.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <TextView
                android:id="@+id/tw_abbrHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="属性"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/iv_strengthIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="3dp"
                android:layout_marginTop="8dp"
                android:src="@drawable/ic_abbr_strength"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tw_abbrHeader" />


            <com.daimajia.numberprogressbar.NumberProgressBar
                android:id="@+id/npb_strength"
                style="@style/NumberProgressBar_Funny_Orange"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/tw_strengthLevel"
                app:layout_constraintTop_toTopOf="@+id/tw_strengthLevel"
                app:progress_current="100"
                app:progress_max="100"
                app:progress_reached_bar_height="5.0dp"
                app:progress_unreached_bar_height="2.5dp" />

            <TextView
                android:id="@+id/tw_strengthExp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="250/500"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@+id/tw_strengthLevel"
                app:layout_constraintTop_toBottomOf="@+id/tw_strengthLevel" />

            <TextView
                android:id="@+id/tw_strengthName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="8dp"
                android:text="力量"
                app:layout_constraintStart_toEndOf="@+id/iv_strengthIcon"
                app:layout_constraintTop_toTopOf="@+id/iv_strengthIcon" />

            <TextView
                android:id="@+id/tw_strengthLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="8dp"
                android:text="LV100"
                android:textColor="@android:color/holo_blue_bright"
                android:textSize="14sp"
                app:layout_constraintStart_toEndOf="@+id/tv_nameFirst"
                app:layout_constraintTop_toTopOf="@+id/iv_strengthIcon" />

            <ImageView
                android:id="@+id/iv_iconFirst"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="18dp"
                android:src="@drawable/ic_abbr_learning"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iv_strengthIcon" />

            <com.daimajia.numberprogressbar.NumberProgressBar
                android:id="@+id/npb_first"
                android:layout_width="200dp"
                android:layout_height="wrap_content"

                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/npb_strength"
                app:layout_constraintTop_toTopOf="@+id/tv_levelFirst"
                app:progress_current="80"
                app:progress_max="100"
                app:progress_reached_bar_height="5.0dp"
                app:progress_unreached_bar_height="2.5dp" />

            <TextView
                android:id="@+id/tw_learningExp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="250/500"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@+id/tv_levelFirst"
                app:layout_constraintTop_toBottomOf="@+id/tv_levelFirst" />

            <TextView
                android:id="@+id/tv_nameFirst"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:text="学识"
                app:layout_constraintStart_toEndOf="@+id/iv_iconFirst"
                app:layout_constraintTop_toTopOf="@+id/iv_iconFirst" />

            <TextView
                android:id="@+id/tv_levelFirst"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="8dp"
                android:text="LV99"
                android:textColor="@android:color/holo_blue_bright"
                android:textSize="14sp"
                app:layout_constraintStart_toEndOf="@+id/tv_nameFirst"
                app:layout_constraintTop_toTopOf="@+id/iv_iconFirst" />

            <ImageView
                android:id="@+id/iv_charmIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="18dp"
                android:src="@drawable/ic_abbr_charm"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iv_iconFirst" />

            <com.daimajia.numberprogressbar.NumberProgressBar
                android:id="@+id/npb_charm"
                style="@style/NumberProgressBar_Passing_Green"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/npb_first"
                app:layout_constraintTop_toTopOf="@+id/tw_charmLevel"
                app:progress_current="80"
                app:progress_max="100"
                app:progress_reached_bar_height="5.0dp"
                app:progress_unreached_bar_height="2.5dp" />

            <TextView
                android:id="@+id/tw_charmExp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="250/500"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@+id/tv_levelFirst"
                app:layout_constraintTop_toBottomOf="@+id/tw_charmLevel" />

            <TextView
                android:id="@+id/tw_charmName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:text="魅力"
                app:layout_constraintStart_toEndOf="@+id/iv_charmIcon"
                app:layout_constraintTop_toTopOf="@+id/iv_charmIcon" />

            <TextView
                android:id="@+id/tw_charmLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="8dp"
                android:text="LV100"
                android:textColor="@android:color/holo_blue_bright"
                android:textSize="14sp"
                app:layout_constraintStart_toEndOf="@+id/tw_charmName"
                app:layout_constraintTop_toTopOf="@+id/iv_charmIcon" />

            <ImageView
                android:id="@+id/iv_enduranceIcon"
