            app:layout_constraintTop_toTopOf="@+id/tv_levelSec"
            app:progress_current="80"
            app:progress_max="100"
            app:progress_reached_bar_height="5.0dp"
            app:progress_unreached_bar_height="2.5dp" />

        <TextView
            android:id="@+id/tv_expSec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="250/500"
            android:textSize="12sp"
            android:visibility="invisible"
            app:layout_constraintStart_toStartOf="@+id/tv_levelSec"
            app:layout_constraintTop_toBottomOf="@+id/tv_levelSec" />

        <TextView
            android:id="@+id/tv_levelSec"
            android:layout_width="35dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:text="LV99"
            android:textColor="@android:color/holo_blue_bright"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@+id/tv_nameSec"
            app:layout_constraintTop_toTopOf="@+id/iv_iconSec" />

        <TextView
            android:id="@+id/tv_nameSec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text="学识"
            app:layout_constraintStart_toEndOf="@+id/iv_iconSec"
            app:layout_constraintTop_toTopOf="@+id/iv_iconSec" />

        <ImageView
            android:id="@+id/iv_iconSec"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_abbr_learning"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.ConstraintLayout
        android:id="@+id/constraintLayout_thr"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingEnd="4dp"
        android:paddingStart="22dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
