            app:layout_constraintTop_toTopOf="@+id/tv_levelThr"
            app:progress_current="80"
            app:progress_max="100"
            app:progress_reached_bar_height="5.0dp"
            app:progress_unreached_bar_height="2.5dp" />

        <TextView
            android:id="@+id/tv_expThr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="250/500"
            android:textSize="12sp"
            android:visibility="invisible"
            app:layout_constraintStart_toStartOf="@+id/tv_levelThr"
            app:layout_constraintTop_toBottomOf="@+id/tv_levelThr" />

        <TextView
            android:id="@+id/tv_levelThr"
            android:layout_width="35dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:text="LV99"
            android:textColor="@android:color/holo_blue_bright"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@+id/tv_nameThr"
            app:layout_constraintTop_toTopOf="@+id/iv_iconThr" />

        <TextView
            android:id="@+id/tv_nameThr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:text="学识"
            app:layout_constraintStart_toEndOf="@+id/iv_iconThr"
